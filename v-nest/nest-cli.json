{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/v-nest/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/v-nest/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/v-nest",
  "projects": {
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "projections": {
      "type": "application",
      "root": "apps/projections",
      "entryFile": "main",
      "sourceRoot": "apps/projections/src",
      "compilerOptions": {
        "tsConfigPath": "apps/projections/tsconfig.app.json"
      }
    },
    "v-nest": {
      "type": "application",
      "root": "apps/v-nest",
      "entryFile": "main",
      "sourceRoot": "apps/v-nest/src",
      "compilerOptions": {
        "tsConfigPath": "apps/v-nest/tsconfig.app.json"
      }
    },
    "worker-engine": {
      "type": "application",
      "root": "apps/worker-engine",
      "entryFile": "main",
      "sourceRoot": "apps/worker-engine/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-engine/tsconfig.app.json"
      }
    }
  }
}